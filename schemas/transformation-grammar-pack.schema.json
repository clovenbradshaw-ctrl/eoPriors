{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "transformation-grammar-pack.schema.json",
  "title": "TransformationGrammarPack@1",
  "type": "object",
  "required": [
    "schema",
    "pack_id",
    "spec_version",
    "operator_epoch",
    "scope",
    "provenance",
    "transformations",
    "admissible_units",
    "domain_constraints",
    "validation_evidence"
  ],
  "properties": {
    "schema": {
      "const": "TransformationGrammarPack@1"
    },
    "pack_id": {
      "$ref": "pack-common.schema.json#/$defs/packId"
    },
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "operator_epoch": {
      "type": "string",
      "pattern": "^eo-\\d{4}-\\d{2}$"
    },
    "scope": {
      "$ref": "pack-common.schema.json#/$defs/scope"
    },
    "provenance": {
      "$ref": "pack-common.schema.json#/$defs/provenance"
    },
    "transformations": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "admissible_units": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "domain_constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
