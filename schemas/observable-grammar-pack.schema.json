{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "observable-grammar-pack.schema.json",
  "title": "ObservableGrammarPack@1",
  "type": "object",
  "required": [
    "schema",
    "pack_id",
    "spec_version",
    "operator_epoch",
    "scope",
    "provenance",
    "applicable_axes",
    "expression_forms",
    "complexity_costs",
    "proposal_weights",
    "known_failure_cases"
  ],
  "properties": {
    "schema": {
      "const": "ObservableGrammarPack@1"
    },
    "pack_id": {
      "$ref": "pack-common.schema.json#/$defs/packId"
    },
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "operator_epoch": {
      "type": "string",
      "pattern": "^eo-\\d{4}-\\d{2}$"
    },
    "scope": {
      "$ref": "pack-common.schema.json#/$defs/scope"
    },
    "provenance": {
      "$ref": "pack-common.schema.json#/$defs/provenance"
    },
    "applicable_axes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expression_forms": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "complexity_costs": {
      "type": "object"
    },
    "proposal_weights": {
      "type": "object"
    },
    "known_failure_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
