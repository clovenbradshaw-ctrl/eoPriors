{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pack-common.schema.json",
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "eventRef": { "type": "string", "pattern": "^event:sha256:[0-9a-f]{64}$" },
    "packId": { "type": "string", "pattern": "^pack:sha256:[0-9a-f]{64}$" },
    "basisId": { "type": "string", "pattern": "^[a-z-]+:sha256:(?!0{64})[0-9a-f]{64}$" },
    "scope": { "$ref": "prior-snapshot.schema.json#/$defs/scope" },
    "provenance": {
      "type": "object",
      "required": ["governance_events", "corpus", "splits", "algorithms", "rights_manifest_id"],
      "properties": {
        "governance_events": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/eventRef" } },
        "corpus": { "type": "string", "minLength": 1 },
        "splits": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "algorithms": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "not": { "pattern": "latest" } } },
        "rights_manifest_id": { "type": "string", "pattern": "^rights:sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": false
    },
    "decimalString": { "type": "string", "pattern": "^-?\\d+(\\.\\d+)?$" },
    "uncertainty": {
      "type": "object",
      "required": ["lower", "upper", "method"],
      "properties": { "lower": { "$ref": "#/$defs/decimalString" }, "upper": { "$ref": "#/$defs/decimalString" }, "method": { "type": "string", "minLength": 1 } },
      "additionalProperties": false
    }
  }
}
