{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "exemplar-basis.schema.json",
  "title": "Exemplar basis",
  "description": "100 texts + selection provenance; a Lens's ground (SPEC.md §1, §5). Proposed by exemplar.basis.selected (batch-writable, human-reviewable, cheap to discard); promoted to status 'active' only by exemplar.basis.activated, which is not batch-writable at all and requires a human-reviewed PR against config/exemplar-basis/active.json (SPEC.md §5.5, invariant 10).",
  "$defs": {
    "sha256Ref": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "phasepostCellKey": {
      "type": "string",
      "enum": [
        "CON_Binding_Link", "CON_Tending_Field", "CON_Tracing_Network",
        "DEF_Clearing_Atmosphere", "DEF_Dissecting_Lens", "DEF_Unraveling_Paradigm",
        "EVA_Binding_Lens", "EVA_Tending_Atmosphere", "EVA_Tracing_Paradigm",
        "INS_Composing_Kind", "INS_Cultivating_Void", "INS_Making_Entity",
        "NUL_Clearing_Void", "NUL_Dissecting_Entity", "NUL_Unraveling_Kind",
        "REC_Composing_Paradigm", "REC_Cultivating_Atmosphere", "REC_Making_Lens",
        "SEG_Clearing_Field", "SEG_Dissecting_Link", "SEG_Unraveling_Network",
        "SIG_Binding_Entity", "SIG_Tending_Void", "SIG_Tracing_Kind",
        "SYN_Composing_Network", "SYN_Cultivating_Field", "SYN_Making_Link"
      ]
    }
  },
  "type": "object",
  "required": [
    "basis_id", "candidate_pool_hash", "classifier", "embedding_model",
    "selection_algorithm", "selected", "coverage", "determinism", "status"
  ],
  "properties": {
    "basis_id": { "type": "string", "pattern": "^exemplar-basis:sha256:[0-9a-f]{64}$" },
    "candidate_pool_hash": { "$ref": "#/$defs/sha256Ref" },
    "classifier": {
      "const": "eo-lexical-analysis-2.0",
      "description": "The one legitimate source of any phasepost claim in the system (invariant 5). Never any other value."
    },
    "embedding_model": {
      "type": "string",
      "pattern": "^\\S+@\\S+$",
      "description": "name@version, pinned. e.g. Xenova/paraphrase-multilingual-MiniLM-L12-v2@2.17"
    },
    "selection_algorithm": {
      "type": "string",
      "pattern": "^[a-z0-9-]+@\\d+\\.\\d+\\.\\d+$",
      "description": "e.g. exemplar-selection@1.0.0 (src/basis-select.js)."
    },
    "selected": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "required": ["candidate_id", "phasepost_scores", "admitted_for_cell"],
        "properties": {
          "candidate_id": { "type": "string" },
          "phasepost_scores": {
            "type": "object",
            "propertyNames": { "$ref": "#/$defs/phasepostCellKey" },
            "minProperties": 27,
            "maxProperties": 27
          },
          "admitted_for_cell": {
            "$ref": "#/$defs/phasepostCellKey",
            "description": "Which coverage gap this candidate was greedily admitted to close (src/basis-select.js)."
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "required": ["cells_covered", "min_cell_confidence_ppm", "per_cell_count"],
      "properties": {
        "cells_covered": { "type": "integer", "minimum": 0, "maximum": 27 },
        "min_cell_confidence_ppm": { "type": "integer", "minimum": 0, "maximum": 1000000 },
        "per_cell_count": {
          "type": "object",
          "propertyNames": { "$ref": "#/$defs/phasepostCellKey" },
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "determinism": {
      "type": "string",
      "enum": ["reproduced", "attested"],
      "description": "attested when embedding is externally-hosted or otherwise not independently regenerable (invariant 4)."
    },
    "status": {
      "type": "string",
      "enum": ["proposed", "active", "superseded"],
      "description": "Only the build workflow may move a basis to 'active', and only after a human-reviewed PR against config/exemplar-basis/active.json (§5.5)."
    },
    "activated_at": { "type": ["string", "null"], "format": "date-time" },
    "activated_via": {
      "type": ["string", "null"],
      "description": "Reference to the human-reviewed PR that activated this basis, when status is active or superseded."
    },
    "superseded_by": { "type": ["string", "null"], "pattern": "^exemplar-basis:sha256:[0-9a-f]{64}$" }
  }
}
